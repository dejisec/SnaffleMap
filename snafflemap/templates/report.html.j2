<script>
(function () {
  "use strict";

  var themeBtn = document.getElementById("themeToggle");
  var iconSun = document.getElementById("iconSun");
  var iconMoon = document.getElementById("iconMoon");

  function updateThemeIcons() {
    var isLight = document.body.classList.contains("light-mode");
    iconSun.style.display = isLight ? "block" : "none";
    iconMoon.style.display = isLight ? "none" : "block";
  }

  if (localStorage.getItem("snafflemap-theme") === "light") {
    document.body.classList.add("light-mode");
  }
  updateThemeIcons();

  themeBtn.addEventListener("click", function () {
    document.body.classList.toggle("light-mode");
    localStorage.setItem(
      "snafflemap-theme",
      document.body.classList.contains("light-mode") ? "light" : "dark"
    );
    updateThemeIcons();
  });

  var tabBtns = document.querySelectorAll(".tab-btn");
  var panels = document.querySelectorAll(".panel");
  tabBtns.forEach(function (btn) {
    btn.addEventListener("click", function () {
      var target = btn.getAttribute("data-tab");
      tabBtns.forEach(function (b) { b.classList.remove("active"); });
      panels.forEach(function (p) { p.classList.remove("active"); });
      btn.classList.add("active");
      var panel = document.getElementById(target);
      if (panel) { panel.classList.add("active"); }
      applyFilters();
    });
  });

  window.toggleSection = function (header) {
    var group = header.parentElement;
    group.classList.toggle("collapsed");
    var arrow = header.querySelector(".section-toggle");
    if (arrow) { arrow.textContent = group.classList.contains("collapsed") ? "\u25B6" : "\u25BC"; }
  };

  window.toggleSnippet = function (cell) {
    cell.classList.toggle("expanded");
  };

  window.sortTable = function (th) {
    if (th.classList.contains("no-sort")) return;
    var table = th.closest("table");
    var tbody = table.querySelector("tbody");
    var rows = Array.from(tbody.querySelectorAll("tr"));
    var colIdx = Array.from(th.parentElement.children).indexOf(th);
    var asc = !th.classList.contains("sort-asc");

    th.closest("thead").querySelectorAll("th").forEach(function (h) {
      h.classList.remove("sort-asc", "sort-desc");
    });
    th.classList.add(asc ? "sort-asc" : "sort-desc");

    rows.sort(function (a, b) {
      var aText = (a.children[colIdx] ? a.children[colIdx].textContent.trim() : "").toLowerCase();
      var bText = (b.children[colIdx] ? b.children[colIdx].textContent.trim() : "").toLowerCase();
      var aNum = parseFloat(aText);
      var bNum = parseFloat(bText);
      if (!isNaN(aNum) && !isNaN(bNum) && String(aNum) === aText && String(bNum) === bText) {
        return asc ? aNum - bNum : bNum - aNum;
      }
      return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
    });
    rows.forEach(function (r) { tbody.appendChild(r); });
  };

  var hideReviewed = false;
  var interestingOnly = false;
  var searchText = "";
  var hiddenSeverities = new Set();

  var sevFilterChks = document.querySelectorAll(".sev-filter-chk");
  sevFilterChks.forEach(function (chk) {
    chk.addEventListener("change", function () {
      var sev = chk.getAttribute("data-severity");
      if (chk.checked) {
        hiddenSeverities.delete(sev);
      } else {
        hiddenSeverities.add(sev);
      }
      applyFilters();
    });
  });

  var resultCounter = document.getElementById("resultCounter");

  function applyFilters() {
    var activePanel = document.querySelector(".panel.active");
    if (!activePanel) return;
    var rows = activePanel.querySelectorAll("tbody tr");
    var total = 0;
    var visible = 0;
    rows.forEach(function (row) {
      total++;
      var isReviewed = row.querySelector(".chk-reviewed") && row.querySelector(".chk-reviewed").checked;
      var isInteresting = row.querySelector(".chk-interesting") && row.querySelector(".chk-interesting").checked;
      var rowText = row.textContent.toLowerCase();
      var rowSev = row.getAttribute("data-severity") || "";
      var show = true;
      if (hideReviewed && isReviewed) show = false;
      if (interestingOnly && !isInteresting) show = false;
      if (searchText && !rowText.includes(searchText)) show = false;
      if (hiddenSeverities.has(rowSev)) show = false;
      row.classList.toggle("hidden-row", !show);
      if (show) visible++;
    });
    if (resultCounter) {
      resultCounter.textContent = "Showing " + visible + " of " + total;
    }
  }

  var searchInput = document.getElementById("searchInput");
  searchInput.addEventListener("input", function () {
    searchText = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  var toggleHR = document.querySelector("#toggleHideReviewed input");
  toggleHR.addEventListener("change", function () {
    hideReviewed = toggleHR.checked;
    applyFilters();
  });

  var toggleInt = document.querySelector("#toggleInteresting input");
  toggleInt.addEventListener("change", function () {
    interestingOnly = toggleInt.checked;
    applyFilters();
  });

  document.addEventListener("change", function (e) {
    if (e.target.classList.contains("chk-reviewed") || e.target.classList.contains("chk-interesting")) {
      applyFilters();
    }
  });

  var toggleUn = document.querySelector("#toggleUnescape input");
  toggleUn.addEventListener("change", function () {
    var unescaped = toggleUn.checked;
    document.querySelectorAll("pre[data-raw]").forEach(function (pre) {
      if (unescaped) {
        var raw = pre.getAttribute("data-raw") || "";
        pre.textContent = raw
          .replace(/&amp;/g, "&")
          .replace(/&lt;/g, "<")
          .replace(/&gt;/g, ">")
          .replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'")
          .replace(/&#x27;/g, "'")
          .replace(/&#x2F;/g, "/");
      } else {
        pre.textContent = pre.getAttribute("data-raw") || "";
      }
    });
  });

  document.getElementById("btnExpandAll").addEventListener("click", function () {
    var activePanel = document.querySelector(".panel.active");
    if (!activePanel) return;
    activePanel.querySelectorAll(".section-group").forEach(function (g) {
      g.classList.remove("collapsed");
      var arrow = g.querySelector(".section-toggle");
      if (arrow) arrow.textContent = "\u25BC";
    });
  });

  document.getElementById("btnCollapseAll").addEventListener("click", function () {
    var activePanel = document.querySelector(".panel.active");
    if (!activePanel) return;
    activePanel.querySelectorAll(".section-group").forEach(function (g) {
      g.classList.add("collapsed");
      var arrow = g.querySelector(".section-toggle");
      if (arrow) arrow.textContent = "\u25B6";
    });
  });

  var focusedRow = null;
  document.addEventListener("keydown", function (e) {
    var tag = (e.target.tagName || "").toLowerCase();
    if (tag === "input" || tag === "textarea") return;

    var key = e.key;
    if (key !== "ArrowUp" && key !== "ArrowDown" && key !== "w" && key !== "s" &&
        key !== "ArrowLeft" && key !== "ArrowRight" && key !== "a" && key !== "d" &&
        key !== " ") return;

    var activePanel = document.querySelector(".panel.active");
    if (!activePanel) return;
    var visibleRows = Array.from(activePanel.querySelectorAll("tbody tr:not(.hidden-row)"));
    if (!visibleRows.length) return;

    if (!focusedRow || !activePanel.contains(focusedRow)) {
      focusedRow = visibleRows[0];
    }

    var idx = visibleRows.indexOf(focusedRow);

    if (key === "ArrowDown" || key === "s") {
      e.preventDefault();
      idx = Math.min(idx + 1, visibleRows.length - 1);
    } else if (key === "ArrowUp" || key === "w") {
      e.preventDefault();
      idx = Math.max(idx - 1, 0);
    } else if (key === " ") {
      e.preventDefault();
      var chk = focusedRow.querySelector(".chk-interesting");
      if (chk) { chk.checked = !chk.checked; applyFilters(); }
      return;
    } else if (key === "ArrowRight" || key === "d") {
      e.preventDefault();
      var chkR = focusedRow.querySelector(".chk-reviewed");
      if (chkR) { chkR.focus(); }
      return;
    } else if (key === "ArrowLeft" || key === "a") {
      e.preventDefault();
      var chkI = focusedRow.querySelector(".chk-interesting");
      if (chkI) { chkI.focus(); }
      return;
    }

    if (focusedRow) { focusedRow.classList.remove("focused"); }
    focusedRow = visibleRows[idx];
    focusedRow.classList.add("focused");
    focusedRow.scrollIntoView({ block: "nearest" });
  });

  var btnSave = document.getElementById("btnSave");
  btnSave.addEventListener("click", function () {
    var clone = document.documentElement.cloneNode(true);

    var origCheckboxes = document.querySelectorAll('input[type="checkbox"]');
    var cloneCheckboxes = clone.querySelectorAll('input[type="checkbox"]');
    origCheckboxes.forEach(function (orig, i) {
      if (cloneCheckboxes[i]) {
        if (orig.checked) {
          cloneCheckboxes[i].setAttribute("checked", "checked");
        } else {
          cloneCheckboxes[i].removeAttribute("checked");
        }
      }
    });

    if (document.body.classList.contains("light-mode")) {
      clone.querySelector("body").classList.add("light-mode");
    }

    var html = "<!DOCTYPE html>\n" + clone.outerHTML;
    var blob = new Blob([html], { type: "text/html;charset=utf-8" });
    var url = URL.createObjectURL(blob);
    var anchor = document.createElement("a");
    anchor.href = url;
    anchor.download = "snafflemap-report-saved.html";
    document.body.appendChild(anchor);
    anchor.click();
    document.body.removeChild(anchor);
    URL.revokeObjectURL(url);
  });

  applyFilters();

})();
</script>
{% endraw %}

</body>
</html>
