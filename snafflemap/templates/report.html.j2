<div class="dashboard">
  <div class="stats-grid">
    <div class="stat-card stat-hero">
      <div class="stat-card-value">{{ stats.total_findings }}</div>
      <div class="stat-card-label">Total Findings</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.file_count }}</div>
      <div class="stat-card-label">Files</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.share_count }}</div>
      <div class="stat-card-label">Shares</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.dir_count }}</div>
      <div class="stat-card-label">Dirs</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.unique_hosts }}</div>
      <div class="stat-card-label">Unique Hosts</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-value">{{ stats.unique_shares }}</div>
      <div class="stat-card-label">Unique Shares</div>
    </div>
  </div>

  <div class="chart-panel">
    <h3>Severity Distribution</h3>
    {% set chart_colors = {"Black": "#c084fc", "Red": "#f87171", "Yellow": "#fbbf24", "Green": "#34d399", "Gray": "#6b7280"} %}
    {% set total_for_chart = stats.total_findings if stats.total_findings > 0 else 1 %}
    {% set circ = 439.82 %}
    {% set r = 70 %}
    <div class="donut-wrap">
      <svg width="180" height="180" viewBox="0 0 180 180" aria-label="Severity distribution chart">
        <circle cx="90" cy="90" r="{{ r }}" fill="none" stroke="var(--border-subtle)" stroke-width="18"/>
        {% set ns = namespace(offset=0) %}
        {% for sev in severities %}
        {% set cnt = severity_counts[sev] %}
        {% if cnt > 0 %}
        {% set seg_len = (cnt / total_for_chart * circ) %}
        {% set color = chart_colors[sev.value] %}
        <circle cx="90" cy="90" r="{{ r }}" fill="none"
                stroke="{{ color }}" stroke-width="18"
                stroke-dasharray="{{ seg_len }} {{ circ - seg_len }}"
                stroke-dashoffset="{{ -ns.offset }}"
                transform="rotate(-90 90 90)"
                opacity="0.85"/>
        {% set ns.offset = ns.offset + seg_len %}
        {% endif %}
        {% endfor %}
      </svg>
      <div class="donut-center">
        <div class="donut-center-val">{{ stats.total_findings }}</div>
        <div class="donut-center-label">Total</div>
      </div>
    </div>
    <div class="chart-legend">
      {% for sev in severities %}
      {% set cnt = severity_counts[sev] %}
      <span class="legend-item">
        <span class="legend-dot" style="background:{{ chart_colors[sev.value] }}"></span>
        {{ sev.value }} {{ cnt }}
      </span>
      {% endfor %}
    </div>
  </div>
</div>

<div class="top-panels">
  <div class="top-panel">
    <h3>Top Hosts</h3>
    {% if top_hosts %}
      {% set max_host_cnt = top_hosts[0][1] if top_hosts else 1 %}
      {% for host, cnt in top_hosts %}
      <div class="top-item">
        <span class="top-rank">{{ loop.index }}</span>
        <span class="top-name">{{ host }}</span>
        <span class="top-bar-wrap"><span class="top-bar" style="width:{{ (cnt / max_host_cnt * 100) | int }}%"></span></span>
        <span class="top-count">{{ cnt }}</span>
      </div>
      {% endfor %}
    {% else %}
      <div style="color:var(--text-muted);font-size:10px;">No host data</div>
    {% endif %}
  </div>
  <div class="top-panel">
    <h3>Top Rules</h3>
    {% if top_rules %}
      {% set max_rule_cnt = top_rules[0][1] if top_rules else 1 %}
      {% for rule, cnt in top_rules %}
      <div class="top-item">
        <span class="top-rank">{{ loop.index }}</span>
        <span class="top-name">{{ rule }}</span>
        <span class="top-bar-wrap"><span class="top-bar" style="width:{{ (cnt / max_rule_cnt * 100) | int }}%"></span></span>
        <span class="top-count">{{ cnt }}</span>
      </div>
      {% endfor %}
    {% else %}
      <div style="color:var(--text-muted);font-size:10px;">No rule data</div>
    {% endif %}
  </div>
</div>

