<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SnaffleMap Report</title>
<style>
:root {
  --bg-void:        #08090d;
  --bg-base:        #0d0f14;
  --bg-surface:     #13161e;
  --bg-elevated:    #191d28;
  --bg-overlay:     #1f2433;
  --bg-hover:       #252b3a;
  --border-subtle:  #1a1f2e;
  --border-default: #242a3a;
  --border-strong:  #333c52;
  --text-primary:   #d4d8e4;
  --text-secondary: #7a8299;
  --text-muted:     #4a5168;
  --accent:         #22d3ee;
  --accent-dim:     rgba(34,211,238,0.12);
  --accent-glow:    rgba(34,211,238,0.06);
  --accent-hover:   #67e8f9;
  --sev-black:      #c084fc;
  --sev-black-bg:   rgba(192,132,252,0.07);
  --sev-red:        #f87171;
  --sev-red-bg:     rgba(248,113,113,0.07);
  --sev-yellow:     #fbbf24;
  --sev-yellow-bg:  rgba(251,191,36,0.07);
  --sev-green:      #34d399;
  --sev-green-bg:   rgba(52,211,153,0.07);
  --sev-gray:       #6b7280;
  --sev-gray-bg:    rgba(107,114,128,0.07);
  --link:           #38bdf8;
  --focus-ring:     rgba(34,211,238,0.45);
  --font-body:      'Consolas', 'SF Mono', 'Cascadia Code', 'Fira Mono', 'DejaVu Sans Mono', monospace;
  --font-display:   'Segoe UI', system-ui, -apple-system, 'Helvetica Neue', sans-serif;
  --header-h:       48px;
  --radius:         3px;
  --transition:     0.15s ease;
}

body.light-mode {
  --bg-void:        #eef0f4;
  --bg-base:        #f4f5f8;
  --bg-surface:     #ffffff;
  --bg-elevated:    #e9ebf0;
  --bg-overlay:     #dde0e8;
  --bg-hover:       #d3d7e2;
  --border-subtle:  #dde0e8;
  --border-default: #c8ccd8;
  --border-strong:  #a0a8b8;
  --text-primary:   #1a1f2e;
  --text-secondary: #5a6178;
  --text-muted:     #8890a4;
  --accent:         #0891b2;
  --accent-dim:     rgba(8,145,178,0.10);
  --accent-glow:    rgba(8,145,178,0.05);
  --accent-hover:   #0e7490;
  --link:           #0284c7;
  --focus-ring:     rgba(8,145,178,0.35);
  --sev-black-bg:   rgba(192,132,252,0.08);
  --sev-red-bg:     rgba(248,113,113,0.08);
  --sev-yellow-bg:  rgba(251,191,36,0.08);
  --sev-green-bg:   rgba(52,211,153,0.08);
  --sev-gray-bg:    rgba(107,114,128,0.08);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg-void);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 12px;
  line-height: 1.55;
  overflow: hidden;
  height: 100vh;
}

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
* { scrollbar-width: thin; scrollbar-color: var(--border-strong) transparent; }

:focus-visible { outline: none; box-shadow: 0 0 0 2px var(--focus-ring); }
a { color: var(--link); text-decoration: none; }
a:hover { text-decoration: underline; }

.app-shell {
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: var(--header-h) 1fr;
  grid-template-areas: "header" "main";
  height: 100vh;
  overflow: hidden;
}

.header-bar {
  grid-area: header;
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-default);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 16px;
  z-index: 100;
}

.header-brand {
  display: flex;
  align-items: center;
  gap: 8px;
}
.header-brand svg { flex-shrink: 0; }
.header-brand h1 {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
}

.header-search {
  flex: 1;
  max-width: 420px;
  position: relative;
}
.header-search svg {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}
.search-input {
  width: 100%;
  background: var(--bg-base);
  color: var(--text-primary);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 6px 10px 6px 32px;
  font-family: var(--font-body);
  font-size: 12px;
  transition: border-color var(--transition);
}
.search-input::placeholder { color: var(--text-muted); }
.search-input:focus { outline: none; border-color: var(--accent); }

.header-actions {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: auto;
}

.icon-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--text-secondary);
  border-radius: var(--radius);
  width: 32px;
  height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--transition);
  font-family: inherit;
}
.icon-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
  border-color: var(--border-default);
}

.main-content {
  grid-area: main;
  overflow-y: auto;
  padding: 16px 20px;
  background: var(--bg-base);
  will-change: transform;
}

.dashboard {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.stat-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-left: 2px solid var(--accent);
  border-radius: var(--radius);
  padding: 10px 12px;
}
.stat-card-value {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
}
.stat-card-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 2px;
}
.stat-card.stat-hero {
  grid-column: span 2;
  background: linear-gradient(135deg, var(--bg-surface), var(--accent-glow));
}
.stat-hero .stat-card-value {
  font-size: 32px;
  color: var(--accent);
}

.chart-panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.chart-panel h3 {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
  align-self: flex-start;
}
.donut-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.donut-center {
  position: absolute;
  text-align: center;
}
.donut-center-val {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}
.donut-center-label {
  font-size: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-muted);
}
.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 10px;
  justify-content: center;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  color: var(--text-secondary);
}
.legend-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.top-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}
.top-panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 12px 14px;
}
.top-panel h3 {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.top-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 0;
  font-size: 11px;
  color: var(--text-secondary);
  border-bottom: 1px solid var(--border-subtle);
}
.top-item:last-child { border-bottom: none; }
.top-rank {
  font-size: 9px;
  font-weight: 700;
  color: var(--text-muted);
  min-width: 14px;
}
.top-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.top-bar-wrap {
  width: 50px;
  height: 4px;
  background: var(--bg-overlay);
  border-radius: 2px;
  overflow: hidden;
  flex-shrink: 0;
}
.top-bar {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  opacity: 0.7;
}
.top-count {
  font-size: 10px;
  font-weight: 600;
  color: var(--accent);
  min-width: 20px;
  text-align: right;
}

.tab-bar {
  display: flex;
  gap: 4px;
  margin-bottom: 12px;
}
.tab-btn {
  background: var(--bg-surface);
  color: var(--text-secondary);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 6px 16px;
  cursor: pointer;
  font-size: 11px;
  font-family: inherit;
  font-weight: 500;
  transition: all var(--transition);
}
.tab-btn:hover { background: var(--bg-hover); color: var(--text-primary); }
.tab-btn.active {
  background: var(--accent-dim);
  color: var(--accent);
  border-color: var(--accent);
  font-weight: 600;
}

.controls-strip {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 8px 14px;
  margin-bottom: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  align-items: center;
}

.toggle-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  user-select: none;
  font-size: 11px;
  color: var(--text-secondary);
}
.toggle-wrap:hover { color: var(--text-primary); }
.toggle-wrap input { display: none; }
.toggle-track {
  width: 28px;
  height: 14px;
  background: var(--bg-overlay);
  border: 1px solid var(--border-strong);
  border-radius: 7px;
  position: relative;
  transition: all var(--transition);
  flex-shrink: 0;
}
.toggle-track::after {
  content: '';
  position: absolute;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--text-muted);
  top: 1px;
  left: 1px;
  transition: all var(--transition);
}
.toggle-wrap input:checked ~ .toggle-track {
  background: var(--accent-dim);
  border-color: var(--accent);
}
.toggle-wrap input:checked ~ .toggle-track::after {
  background: var(--accent);
  transform: translateX(14px);
}

.sev-filter-item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  color: var(--text-secondary);
  cursor: pointer;
}
.sev-filter-item:hover { color: var(--text-primary); }
.sev-filter-item input[type="checkbox"] {
  appearance: none;
  -webkit-appearance: none;
  width: 12px;
  height: 12px;
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  background: var(--bg-base);
  cursor: pointer;
  position: relative;
  flex-shrink: 0;
}
.sev-filter-item input[type="checkbox"]:checked {
  background: var(--accent);
  border-color: var(--accent);
}
.sev-filter-item input[type="checkbox"]:checked::after {
  content: '';
  position: absolute;
  left: 2px;
  top: 0px;
  width: 5px;
  height: 7px;
  border: solid var(--bg-void);
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
}

.sev-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.sev-dot-black  { background: var(--sev-black); }
.sev-dot-red    { background: var(--sev-red); }
.sev-dot-yellow { background: var(--sev-yellow); }
.sev-dot-green  { background: var(--sev-green); }
.sev-dot-gray   { background: var(--sev-gray); }

.controls-sep {
  width: 1px;
  height: 16px;
  background: var(--border-default);
  flex-shrink: 0;
}

.result-counter {
  font-size: 10px;
  color: var(--text-muted);
  margin-left: auto;
}

.ctrl-btn {
  background: var(--bg-overlay);
  color: var(--text-secondary);
  border: 1px solid var(--border-default);
  border-radius: var(--radius);
  padding: 4px 10px;
  cursor: pointer;
  font-size: 10px;
  font-family: inherit;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all var(--transition);
}
.ctrl-btn:hover { background: var(--bg-hover); color: var(--text-primary); }

.section-group { margin-bottom: 8px; }
.section-header {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius) var(--radius) 0 0;
  padding: 6px 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  user-select: none;
}
.section-header:hover { background: var(--bg-elevated); }
.section-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-primary);
}
.section-toggle {
  color: var(--text-muted);
  font-size: 10px;
  margin-left: auto;
  transition: transform var(--transition);
}
.badge {
  font-size: 9px;
  font-weight: 700;
  background: var(--accent-dim);
  color: var(--accent);
  border-radius: 2px;
  padding: 1px 6px;
  letter-spacing: 0.5px;
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--border-default);
  border-top: none;
  border-radius: 0 0 var(--radius) var(--radius);
  contain: layout style paint;
}
.collapsed .table-wrap { display: none; }
.collapsed .section-header { border-radius: var(--radius); }

table {
  border-collapse: collapse;
  width: 100%;
  font-size: 11px;
}

thead th {
  background: var(--bg-elevated);
  color: var(--text-muted);
  padding: 6px 8px;
  text-align: left;
  font-weight: 700;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  white-space: nowrap;
  user-select: none;
  border-bottom: 1px solid var(--border-default);
  position: sticky;
  top: 0;
  z-index: 2;
  transition: background var(--transition);
}
thead th:hover { background: var(--bg-overlay); color: var(--text-secondary); }
th.sort-asc::after  { content: " \25B2"; color: var(--accent); font-size: 8px; }
th.sort-desc::after { content: " \25BC"; color: var(--accent); font-size: 8px; }
th.no-sort { cursor: default; }
th.no-sort:hover { background: var(--bg-elevated); color: var(--text-muted); }
th.th-center { text-align: center; }

tbody tr {
  border-left: 3px solid transparent;
}
tbody td {
  padding: 5px 8px;
  vertical-align: top;
  border-bottom: 1px solid var(--border-subtle);
  white-space: nowrap;
}
tbody tr:last-child td { border-bottom: none; }

tbody tr:nth-child(even) td { background: var(--bg-surface); }
tbody tr:nth-child(odd) td { background: var(--bg-base); }

tr.sev-black  { border-left-color: var(--sev-black); }
tr.sev-red    { border-left-color: var(--sev-red); }
tr.sev-yellow { border-left-color: var(--sev-yellow); }
tr.sev-green  { border-left-color: var(--sev-green); }
tr.sev-gray   { border-left-color: var(--sev-gray); }

tbody tr:hover td { background: var(--bg-hover) !important; }
tbody tr.focused td { box-shadow: inset 0 0 0 1px var(--accent); }

.sev-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  font-weight: 700;
  white-space: nowrap;
  letter-spacing: 0.5px;
}
.sev-pill::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.sev-pill-Black  { color: var(--sev-black); }
.sev-pill-Black::before  { background: var(--sev-black); }
.sev-pill-Red    { color: var(--sev-red); }
.sev-pill-Red::before    { background: var(--sev-red); }
.sev-pill-Yellow { color: var(--sev-yellow); }
.sev-pill-Yellow::before { background: var(--sev-yellow); }
.sev-pill-Green  { color: var(--sev-green); }
.sev-pill-Green::before  { background: var(--sev-green); }
.sev-pill-Gray   { color: var(--sev-gray); }
.sev-pill-Gray::before   { background: var(--sev-gray); }

.perm-dots {
  display: inline-flex;
  gap: 3px;
  align-items: center;
}
.perm-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  border: 1px solid var(--border-strong);
  background: transparent;
}
.perm-dot.perm-active { border: none; }
.perm-r.perm-active { background: var(--sev-green); }
.perm-w.perm-active { background: var(--sev-yellow); }
.perm-m.perm-active { background: var(--sev-red); }

.path-cell {
  white-space: normal !important;
  max-width: 300px;
  word-break: break-all;
}
.path-filename {
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.path-full {
  font-size: 10px;
  color: var(--text-muted);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.path-folder {
  font-size: 9px;
  color: var(--link);
  opacity: 0.7;
}
.path-folder:hover { opacity: 1; }

.snippet-cell {
  cursor: pointer;
  white-space: normal !important;
}
.snippet-preview {
  display: block;
  background: var(--bg-void);
  border: 1px solid var(--border-subtle);
  border-radius: 2px;
  padding: 3px 6px;
  font-family: var(--font-body);
  font-size: 10px;
  color: var(--text-secondary);
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 32px;
  overflow-y: auto;
  line-height: 1.4;
}
.snippet-full {
  display: none;
  background: var(--bg-void);
  border: 1px solid var(--border-default);
  border-radius: 2px;
  padding: 6px 8px;
  font-family: var(--font-body);
  font-size: 10px;
  color: var(--text-primary);
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 200px;
  overflow-y: auto;
  margin-top: 4px;
  line-height: 1.5;
}
.snippet-cell.expanded .snippet-preview { display: none; }
.snippet-cell.expanded .snippet-full { display: block; }

.chk-cell { text-align: center; }
.chk-cell input[type="checkbox"] {
  appearance: none;
  -webkit-appearance: none;
  width: 14px;
  height: 14px;
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  background: var(--bg-base);
  cursor: pointer;
  position: relative;
  vertical-align: middle;
}
.chk-cell input[type="checkbox"]:checked {
  background: var(--accent);
  border-color: var(--accent);
}
.chk-cell input[type="checkbox"]:checked::after {
  content: '';
  position: absolute;
  left: 3px;
  top: 1px;
  width: 5px;
  height: 8px;
  border: solid var(--bg-void);
  border-width: 0 2px 2px 0;
  transform: rotate(45deg);
}

tr.hidden-row { display: none !important; }
.panel { display: none; }
.panel.active { display: block; }

.date-range {
  font-size: 10px;
  color: var(--text-muted);
  margin-bottom: 12px;
  padding: 0 2px;
}

@media (max-width: 900px) {
  .dashboard { grid-template-columns: 1fr; }
  .top-panels { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .stat-card.stat-hero { grid-column: span 2; }
  .header-brand h1 { font-size: 11px; }
  .header-search { max-width: 200px; }
  .tab-bar { flex-wrap: wrap; }
}
</style>
</head>
<body>

<div class="app-shell">

<header class="header-bar">
  <div class="header-brand">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--accent)">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
    </svg>
    <h1>SnaffleMap</h1>
  </div>
  <div class="header-search">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" class="search-input" id="searchInput" placeholder="Filter findings..." autocomplete="off" />
  </div>
  <div class="header-actions">
