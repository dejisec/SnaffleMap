<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8"><title>SnaffleMap Evidence Pack</title>
<style>
  body { font-family: 'Segoe UI', system-ui, sans-serif; color: #111; max-width: 820px; margin: 24px auto; padding: 0 16px; }
  h1 { font-size: 20px; } h2 { font-size: 15px; border-bottom: 1px solid #ddd; padding-bottom: 4px; margin-top: 28px; }
  .meta { font-size: 13px; } .meta b { display: inline-block; min-width: 130px; }
  code, pre { font-family: 'Consolas', monospace; background: #f4f4f6; }
  pre { padding: 8px; border: 1px solid #e3e3e8; border-radius: 4px; white-space: pre-wrap; word-break: break-all; font-size: 12px; }
  .sev { font-weight: 700; } .cred { color: #b00; }
  @media print { h2 { page-break-inside: avoid; } a { color: #000; } }
</style></head><body>
<h1>SnaffleMap Evidence Pack</h1>
<p>{{ count }} finding(s).</p>
{% for v in views %}
<h2>{{ v.title }} — <span class="sev">{{ v.severity }}</span> ({{ v.tier }} {{ v.score }})</h2>
<div class="meta">
  <div><b>Host:</b> {{ v.host }}</div>
  <div><b>Path:</b> <code>{{ v.path }}</code></div>
  <div><b>Score:</b> {{ v.score }}/100 ({{ v.tier }})</div>
  {% if v.why %}<div><b>Why it matters:</b> {{ v.why }}</div>{% endif %}
  {% if v.action %}<div><b>Recommended action:</b> <code>{{ v.action }}</code></div>{% endif %}
  {% if v.credentials %}<div><b>Credentials:</b><ul>
    {% for c in v.credentials %}<li class="cred">{{ c.type }}: {% if c.username %}{{ c.username }} : {% endif %}<code>{{ c.secret }}</code></li>{% endfor %}
  </ul></div>{% endif %}
  {% if v.snippet %}<div><b>Matched:</b><pre>{{ v.snippet }}</pre></div>{% endif %}
  {% if v.context and v.context != v.snippet %}<div><b>Context:</b><pre>{{ v.context }}</pre></div>{% endif %}
  <div><b>Remediation:</b> {{ v.remediation }}</div>
  <div><b>Sources:</b> {{ v.sources | join(", ") }}</div>
  <div><b>Finding ID:</b> <code>{{ v.id }}</code></div>
</div>
{% endfor %}
</body></html>
